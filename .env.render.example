# Environment variables to set in the Render dashboard
# (Render → your Web Service → Environment). Do NOT commit real secrets.

APP_NAME="Laravel Demo API"
APP_ENV=production
APP_KEY=            # generate: php artisan key:generate --show   (paste the base64:... value)
APP_DEBUG=false
APP_URL=https://your-api.onrender.com   # your Render service URL

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database: Aiven MySQL (SSL is required) ---
DB_CONNECTION=mysql
DB_HOST=your-service.aivencloud.com
DB_PORT=              # Aiven gives a non-3306 port
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=
# Path to Aiven's CA cert inside the repo (committed; it is public, not a secret).
MYSQL_ATTR_SSL_CA=/var/www/html/storage/certs/aiven-ca.pem

# Sessions / cache / queue use the database (tables created by migrations).
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- File storage: AWS S3 ---
UPLOAD_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Optional: set to a CloudFront/CDN URL if the bucket is not public.
# AWS_URL=

# --- CORS: which frontends may call the API ---
# Any *.vercel.app origin is already allowed. Add custom domains here, comma-separated.
FRONTEND_URLS=https://vue-demo-website.vercel.app,https://vue-demo-admin.vercel.app
